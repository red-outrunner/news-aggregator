# Copy this file to .env.local and fill in your keys

# Required. Free key from https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Optional. Stock quotes fall back to Yahoo Finance without it.
# Free key from https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
